
{% block hero %}{% endblock %}
{% block sidebar %}{% endblock %}

{% block content %}

    <div class="card card-reset container">

        <div class="card-header pb-3">
            <h1 class="card-title mb-0">{{ title }}</h1>
        </div>

        {% if favorites_empty %}

            <div class="card-body py-5 text-center text-muted">
                <i class="fa-regular fa-heart fa-3x mb-3 d-block"></i>
                <p class="mb-0">{{ translate("You haven't added any favorites yet.") }}</p>
            </div>

        {% else %}

            {% include "partials/pagination/pagination-advanced.twig" with {
                container  : ".products",
                post_type  : post_type,
                direction  : "prev"
            } %}

            <div class="card-body">
                {# .products — loop-start.php ile aynı grid class'ları, AJAX append hedefi #}
                <div class="products row {{ function('woo_archive_grid', 2, {'md': post_pagination[post_type].catalog_columns ?? 3, 'lg': post_pagination[post_type].catalog_columns ?? 3}) }} g-lg-5 g-4">
                    {{ loop_html|raw }}
                </div>
            </div>

            {% include "partials/pagination/pagination-advanced.twig" with {
                container  : ".products",
                post_type  : post_type,
                direction  : "next"
            } %}

        {% endif %}

    </div>

{% endblock %}
