{% set block_main_field = [] %}
{% set block_extras = {"classes" : "position-relative"} %}
{% extends "blocks/_block-container.twig" %}

{% block block_content %}
    {% set parallax_attrs = {} %}
    {% set is_lcp = function('image_is_lcp', fields.image) %}
    {{img({src: fields.image, class: fields.image_class, attrs: parallax_attrs, wrapper: true, lazy: (not is_lcp and not is_preview), lcp: is_lcp})}}
{% endblock %}