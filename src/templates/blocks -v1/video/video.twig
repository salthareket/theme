{#
  Title: Video
  Description: Video
  Category: saltblocks
  Icon: video-alt3
  Keywords: video film movie
  Mode: auto
  Align: 
  PostTypes: 
  SupportsAlign: left right center wide full
  SupportsAlignContent: true
  SupportsMode: true
  SupportsMultiple: true
  SupportsAnchor: true
  SupportsCustomClassName: true
  SupportsReusable: true
  SupportsFullHeight: true
  ApiVersion: 2
#}
{% set block_main_field = [] %}
{% set block_iterable = [] %}
{% set block_extras = { classes : "position-relative" ~ (fields.video_settings.videoBg?" overflow-hidden":""), container : "z-1 position-relative" } %}
{% set block_required_js = [ "plyr" ] %}
{% extends "blocks/_block-container.twig" %}

{% block block_content %}

    {% if fields.wrapper_class %}
        <div class="{{fields.wrapper_class}} w-100">
    {% endif %}

    {% if fields.template_block %}
        {{ include(
                fields.template_block,
                { fields: fields }, 
                ignore_missing = true)
        }}
    {% else %}
        {# İlk block ve hero ise above-the-fold olarak işaretle #}
        {% set is_above_fold = (block_meta.index == 0 or block_meta.settings.hero) %}
        {% set is_lcp = function('video_is_lcp', fields) %}
        
        {{  video({
                src: fields,
                class: "", 
                init: true, 
                lazy: (not is_lcp and not is_above_fold and not is_preview),
                above_fold: (is_above_fold or is_lcp),
                attrs: fields.wrapper_class?[]:parallax_attrs
            })
        }}
    {% endif %}

    {% if fields.wrapper_class %}
        </div>
    {% endif %}

{% endblock %}