        {% if not user.is_profile_completed and user.get_status() %}
            {% set page_settings = page_settings|merge({ alert: page_settings.alert|merge({position: "bottom", fixed: true, html: "<div class='container text-center'><a href='" ~ base_urls.profile ~"' class='btn btn-danger btn-extend btn-sm'>Please complete your profile</a></div>"}) }) %}
        {% endif %}
    {% endif #}

    {# include "partials/base/user-completion.twig" #}
    
    {#
            Blocks:
                main_class
                main_content_class
                main_container_class

            {% set  page_settings = {
                        full : true,
                        classes : {
                            body : "",
                            main : "",
                            content : "mt-0",
                            container : "",
                            gap : ""
                        },
                        offcanvas : {
                            size : "md"
                        },
                        alert : {
                            type : "danger",
                            title : "",
                            message : "",
                            position : "top",
                fixed : false,
                class : "",
                html : ""
                        }
                    }
            %}
    #}

    {% set body_classes = body_class ~ " " ~ page_settings.classes.body %}
    {% if block_hero or block('hero')|trim is not empty %}
        {% set body_classes = body_classes ~ " " ~ "has-hero" %}
    {% endif %}
    {% if block('header_container')|trim is empty %}
        {% set body_classes = body_classes ~ " " ~ "pt-0" %}
    {% endif %}
    {% if "affix" not in page_settings.classes.body %}
        {% if header_options.affix and (header_options.fixed == "top" or header_options.fixed == "bottom-start") %}
            {% set body_classes = body_classes ~ " " ~ "affixed" %}
            {% if header_options.header_hide_on_scroll_down %}
                {% set body_classes = body_classes ~ " " ~ "header-hide-on-scroll" %}
            {% endif %}
            {% if header_options.fixed %}
                {% set body_classes = body_classes ~ " " ~ "header-affix-" ~ header_options.fixed %}
            {% endif %}
        {% endif %}
        {% if header_options.fixed %}
            {% set body_classes = body_classes ~ " " ~ "header-fixed-" ~ header_options.fixed %}
        {% endif %}
    {% else %}
        {% set body_classes = body_classes ~ " " ~ "header-fixed-top" %}
    {% endif %}

    {% set header_classes = "header" %}
    {% if "affix" in page_settings.classes.body %}
        {% set header_classes = header_classes ~ " " ~ "affix affixed fixed-top" %}
    {% else %}
        {% if header_options.fixed %}
            {% set header_classes = header_classes ~ " " ~ "fixed-" ~ header_options.fixed %}
            {% if header_options.fixed in ["top", "bottom-start"]  %}
                {% if header_options.affix or header_options.fixed == "bottom-start" %}
                    {% set header_classes = header_classes ~ " " ~ "affixed" %}

                {% endif %}
            {% endif %}
        {% endif %}
    {% endif %}
    

  	<body class="{{body_classes}}">

        {{ function('wp_body_open') }}

        {% if block_hero %}
            {{ function("render_block", block_hero) }}
        {% endif %}
        
        {% include "partials/alerts/alert-page.twig" with { alert:page_settings.alert, position : "top" } %}

        {% block header_container %}
            <header id="header" class="{{header_classes}}" itemtype="https://schema.org/WPHeader" itemscope="" role="banner" data-affix-offset="50">
                {% block header %}
                    {% include "partials/header/header.twig" with { container: ""} %}
                {% endblock %}
            </header>
        {% endblock %}
        
        {% if header_options %}
            {% set header_tools = header_options.start.tools|merge(header_options.center.tools)|merge(header_options.end.tools) %}
            {% set rendered_offcanvas = [] %}
            {% for item in header_tools %}
                {% if item.menu_type == "offcanvas" and item.menu_item not in rendered_offcanvas %}
                    {% set rendered_offcanvas = rendered_offcanvas|merge([item.menu_item]) %}
                    {{include(
                        "partials/base/offcanvas-" ~ item.menu_item ~ ".twig", 
                        ignore_missing = true
                    )}}
                {% endif %}
            {% endfor %}
        {% endif %}

        {% if not block('sidebar')|trim|raw is empty and page_settings.offcanvas.individual %}
            {{ block('sidebar') }}
        {% endif %}

        {% block after_header %}
        {% endblock %}

        {% block hero %}
        {% endblock %}



        <main id="main" role="main" class="main flex-column {{page_settings.classes.main}}" {% block microdata %}{% endblock %}>
            
                {% set has_sidebar_toggler = block('sidebar_toggler')|trim is not empty %}
                {% if has_sidebar_toggler and not page_settings.offcanvas.individual %}
                   <div class="sidebar-toggler-container d-block d-{{page_settings.offcanvas.size}}-none sticky-top">
                    {% block sidebar_toggler %}
                    {% endblock %}
                   </div>
                {% endif %}

                {% block hero_header %}
                {% endblock %}

                {% if not page_settings.full and page_settings.classes.container %}
                    <div class="{% if page_settings.classes.container %}{{page_settings.classes.container}}{% else %}{{function("block_container", "default")}}{% endif %}">
                {% else %}
                    {#<div class="container-fluid p-0">#}
                {% endif %}
                    
                    {% if enable_ecommerce %}
                    {% block shop_header %}
                    {% endblock %}
                    {% endif %}

                    {% block before_container %}
                    {% endblock %}

                    {% if (not block('sidebar')|trim|raw is empty and not page_settings.offcanvas.individual) %}
                        <div class="row h-100 {{page_settings.classes.gap|default("gx-lg--5")}} {% if page_settings.offcanvas.position == "right" %}flex-row-reverse{% endif %}">
                            {% block sidebar %}
                            {% endblock %}
                            <div id="content" class="{{function("acf_offcanvas_content_classes", page_settings)}} base">
                    {% endif %}
                        
                            {% block content %}
                                Sorry, no content
                            {% endblock %}

                    {% if (not block('sidebar')|trim|raw is empty and not page_settings.offcanvas.individual) %}
                            </div>
                        </div>
                    {% endif %}

                {% if not page_settings.full and page_settings.classes.container %}
                    </div>
                {% else %}
                    {#</div>#}
                {% endif %}

                {% block bottom %}
                {% endblock %}
        </main>

        {% block offcanvas %}
        {% endblock %}

        {% block after_main %}
        {% endblock %}

        {% block footer %}
             {% if visibility_under_construction or (not visibility_under_construction and user.get_role == "administrator") %}
             {% include 'footer.twig' %}
             {% endif %}
  		{% endblock %}

        {{ function('wp_footer') }}

        {% if site_assets_js and not fetch %}
        <script type="text/javascript">
            window.addEventListener('load', function() {
                {{ site_assets_js }}
            });
        </script>
        {% endif %}

        {% include "partials/alerts/alert-page.twig" with { alert:page_settings.alert, position : "bottom" } %}

        {% block appendix %}
        {% endblock %}

        {% include "partials/modals/modal-home.twig" %}

        {% if enable_notifications and enable_web_push and user.logged %}
        {# ── Web Push Banner CSS ── #}
        <style>
        .sh-push-banner{position:fixed;bottom:0;left:0;right:0;z-index:1050;padding:12px 16px;background:var(--ts-gray-900,#1e1e1e);color:#fff;box-shadow:0 -2px 12px rgba(0,0,0,.18);animation:shBannerIn .3s ease}
        @keyframes shBannerIn{from{transform:translateY(100%)}to{transform:translateY(0)}}
        .sh-push-banner-inner{display:flex;align-items:center;gap:12px;max-width:900px;margin:0 auto}
        .sh-push-banner-icon{font-size:22px;flex-shrink:0}
        .sh-push-banner-text{flex:1;display:flex;flex-direction:column;gap:2px;min-width:0}
        .sh-push-banner-text strong{font-size:14px;font-weight:600;line-height:1.2}
        .sh-push-banner-text span{font-size:12px;opacity:.75;line-height:1.3}
        .sh-push-banner-btn{flex-shrink:0;white-space:nowrap}
        .sh-push-banner-close{flex-shrink:0;background:none;border:none;color:#fff;opacity:.6;cursor:pointer;font-size:16px;padding:4px 6px;line-height:1;transition:opacity .2s}
        .sh-push-banner-close:hover{opacity:1}
        @media(max-width:576px){.sh-push-banner-text span{display:none}}
        </style>
        {# ── Web Push Banner — kullanıcı henüz subscribe olmamışsa gösterilir ── #}
        <div class="sh-push-banner" style="display:none" role="alert" aria-live="polite">
            <div class="sh-push-banner-inner">
                <span class="sh-push-banner-icon">🔔</span>
                <div class="sh-push-banner-text">
                    <strong>{{ "Bildirimleri Aç"|trans }}</strong>
                    <span>{{ "Yeni bildirimlerden anında haberdar ol."|trans }}</span>
                </div>
                <button type="button" class="sh-push-banner-btn btn btn-primary btn-sm" onclick="window.shPushSubscribe(this)">
                    {{ "Aktif Et"|trans }}
                </button>
                <button type="button" class="sh-push-banner-close" onclick="this.closest('.sh-push-banner').remove()" aria-label="{{ 'Kapat'|trans }}">&#10005;</button>
            </div>
        </div>
        <script>
        (function(){
            // Push API desteği yok — çık
            if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;

            // Kullanıcı daha önce reddetmiş — banner gösterme
            if (typeof Notification !== 'undefined' && Notification.permission === 'denied') return;

            var shNotify = window.shNotify || {};
            var VAPID_KEY = shNotify.vapidKey || '';

            function urlBase64ToUint8Array(base64String) {
                var padding = '='.repeat((4 - base64String.length % 4) % 4);
                var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
                var rawData = window.atob(base64);
                var output = new Uint8Array(rawData.length);
                for (var i = 0; i < rawData.length; ++i) output[i] = rawData.charCodeAt(i);
                return output;
            }

            function showBanner() {
                document.querySelectorAll('.sh-push-banner').forEach(function(el){ el.style.display = ''; });
            }
            function hideBanner() {
                document.querySelectorAll('.sh-push-banner').forEach(function(el){ el.remove(); });
            }

            function init() {
                if (!VAPID_KEY) {
                    showBanner();
                    window.shPushSubscribe = function(btn) {
                        if (btn) btn.disabled = true;
                        Notification.requestPermission().then(function(perm) {
                            if (perm === 'granted') { hideBanner(); }
                            else if (btn) { btn.disabled = false; }
                        });
                    };
                    return;
                }

                navigator.serviceWorker.register('/salthub/sw-notify.js')
                    .then(function(reg) {
                        window._swReg = reg;
                        return reg.pushManager.getSubscription();
                    })
                    .then(function(sub) {
                        if (sub) { hideBanner(); } else { showBanner(); }
                    })
                    .catch(function(err) {
                        console.warn('[Push SW]', err);
                        showBanner();
                    });

                window.shPushSubscribe = function(btn) {
                    if (btn) { btn.disabled = true; btn.textContent = '...'; }

                    var doSubscribe = function(reg) {
                        reg.pushManager.subscribe({
                            userVisibleOnly: true,
                            applicationServerKey: urlBase64ToUint8Array(VAPID_KEY)
                        })
                        .then(function(sub) {
                            return fetch(shNotify.ajaxUrl, {
                                method: 'POST',
                                body: new URLSearchParams({
                                    action: 'sh_notify_push_subscribe',
                                    subscription: JSON.stringify(sub),
                                    _wpnonce: shNotify.pushNonce || ''
                                })
                            });
                        })
                        .then(function() { hideBanner(); })
                        .catch(function(err) {
                            console.warn('[Push Subscribe]', err);
                            if (btn) { btn.disabled = false; btn.textContent = '🔔 Aktif Et'; }
                        });
                    };

                    if (window._swReg) {
                        doSubscribe(window._swReg);
                    } else {
                        navigator.serviceWorker.register('/salthub/sw-notify.js')
                            .then(function(reg) { window._swReg = reg; doSubscribe(reg); })
                            .catch(function(err) {
                                console.warn('[Push SW Register]', err);
                                if (btn) { btn.disabled = false; btn.textContent = '🔔 Aktif Et'; }
                            });
                    }
                };
            }

            // DOM hazır olunca başlat
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();
        </script>
        {% endif %}

        {% if theme_styles.utilities.scroll_to_top.show != "no" and theme_styles.utilities.scroll_to_top.active %}
            <a class="scroll-to-top {% if theme_styles.utilities.scroll_to_top.show != "always" %}fade{% endif %}" data-show="{{theme_styles.utilities.scroll_to_top.show}}" data-duration="{{theme_styles.utilities.scroll_to_top.duration}}" href="#" title="{{translate("Sayfa başına git")}}">{{theme_styles.utilities.scroll_to_top.icon}}</a>
        {% endif %}

  	</body>
</html>