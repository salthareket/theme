<li class="list-group-item notification-item infinite-item" data-type="{{ type }}" data-id="{{ post.id }}">
    <div class="product-tease py-2">
        <a href="{{ post.url ?? '#' }}" class="btn-loading-page d-flex" title="{{ post.message|striptags }}">
            {% if post.sender.image %}
                <div class="image">{{ post.sender.image }}</div>
            {% endif %}
            <div class="detail">
                <div class="title">{{ post.sender.name ?? '' }}</div>
                <div class="description">
                    {{ post.message|striptags|truncate(10) }}
                    <small class="date">{{ post.time ?? '' }}</small>
                </div>
            </div>
        </a>
    </div>
</li>
