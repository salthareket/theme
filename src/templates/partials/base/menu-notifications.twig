{% if enable_notifications %}
    {% if menu_type == "dropdown" %}
       {% set toggle = "dropdown" %}
       {% set class =  menu_class ~ " dropdown dropdown-notifications dropdown-form" %}
       {% set target = "" %}
    {% else %}
       {% set toggle = "offcanvas" %}
       {% set class = menu_class ~ "" %}
       {% set target = "offcanvasNotifications" %}
    {% endif %}

    <div class="nav-item {{class}}" data-type="notifications">

        <a href="#" role="button" data-bs-toggle="{{toggle}}" data-bs-target="#{{target}}" aria-controls="{{target}}" title="{{ translate("Notifications") }}">
            <div class="notification-count {% if user.notifications_count == 0 %}d-none{% endif %}">{{user.notifications_count}}</div>
            <i class="fa-light fa-bell"></i>
        </a>

        {% if menu_type == "dropdown" %}
            <div class="dropdown-menu">
                <div class="dropdown-header">
                    <div class="title">{{translate("Notifications")}}</div>
                    <div class="action">
                        <a href="#" data-dismiss="dropdown">{{translate("Close")}}</a>
                    </div>
                </div>
                <div class="dropdown-container load-container">
                    <div class="dropdown-body scrollable">
                        <div class="content">
                            <div class="content-block">
                                <i class="fa-light fa-bell"></i>
                                {{translate("You have no any notification.")}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        
    </div>
{% endif %}